# Copy to .env and adjust. Generate ENCRYPTION_KEY: openssl rand -hex 32
NODE_ENV=development

# After setting DATABASE_URL, apply Prisma migrations once: npm run db:migrate:deploy
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/monitor_status?schema=public"
REDIS_URL="redis://localhost:6379"

# Required for encrypting sensitive data like Evolution API Keys
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# OSS dashboard gate (optional). When not "false", /dashboard and /api require unlock cookie.
# APP_ACCESS_LOCK=false
# Same value as this env = access password (no UI setup). Env wins over DB passwordHash.
# OSS_ACCESS_PASSWORD=

# Evolution API / Health Check Config (Optional)
# PING_TIMEOUT_MS=5000
# RESTART_TIMEOUT_MS=10000

# WhatsApp alerts (Pilot Status Integration) (Optional)
# MONITOR_STATUS_API_KEY=
# MONITOR_STATUS_BASE_URL=https://api.pilotstatus.online
# Template ID approved in Pilot Status (not the per-project alert message body)
# MONITOR_STATUS_TEMPLATE_ID=default
