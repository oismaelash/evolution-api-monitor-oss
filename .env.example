# Copy to .env and adjust. Generate ENCRYPTION_KEY: openssl rand -hex 32

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pilot_status?schema=public"
REDIS_URL="redis://localhost:6379"
NEXTAUTH_SECRET="replace-with-at-least-32-chars-secret-string-here"
NEXTAUTH_URL="http://localhost:3000"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Optional cloud
CLOUD_BILLING=false
CLOUD_ADVANCED_ALERTS=false
CLOUD_EXPONENTIAL_RETRY=false

# Pilot Status (alerts)
# PILOT_STATUS_API_KEY=
# PILOT_STATUS_BASE_URL=https://api.pilotstatus.online

# Stripe / Pague (when CLOUD_BILLING=true)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAGUE_DEV_WEBHOOK_SECRET=
