# Copy to .env and adjust. Generate ENCRYPTION_KEY: openssl rand -hex 32
NODE_ENV=development

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/monitor_status?schema=public"
REDIS_URL="redis://localhost:6379"
NEXTAUTH_SECRET="replace-with-at-least-32-chars-secret-string-here"
NEXTAUTH_URL="http://localhost:3000"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Optional UI/Auth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_ID=
# GITHUB_SECRET=
# BULL_BOARD_SECRET=

# Evolution API / Health Check Config
# PING_TIMEOUT_MS=5000
# RESTART_TIMEOUT_MS=10000

# Optional cloud features
CLOUD_BILLING=false
CLOUD_ADVANCED_ALERTS=false
CLOUD_EXPONENTIAL_RETRY=false

# WhatsApp alerts (Pilot Status Integration)
# MONITOR_STATUS_API_KEY=
# MONITOR_STATUS_BASE_URL=https://api.pilotstatus.online

# Billing Integration (Stripe / Pague Dev)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# BILLING_PRICE_PER_NUMBER_CENTS=500
# PAGUE_DEV_API_KEY=
# PAGUE_DEV_WEBHOOK_SECRET=
# PAGUE_DEV_BASE_URL=https://api.pague.dev/v1
