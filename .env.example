# Copy to .env and adjust. Generate ENCRYPTION_KEY: openssl rand -hex 32
NODE_ENV=development

# After setting DATABASE_URL, apply Prisma migrations once: npm run db:migrate:deploy
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/monitor_status?schema=public"
REDIS_URL="redis://localhost:6379"
NEXTAUTH_SECRET="replace-with-at-least-32-chars-secret-string-here"
# Required if GOOGLE_* or GITHUB_* OAuth vars are set — must match the URL you open in the browser (scheme + host + port).
NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_DEBUG=true  # optional verbose NextAuth logs (can include OAuth secrets/tokens — do not use in prod)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Optional UI/Auth (if you enable Google or GitHub, NEXTAUTH_URL above is required)
# Google: https://next-auth.js.org/providers/google — Authorized redirect URIs must include:
#   {NEXTAUTH_URL}/api/auth/callback/google   e.g. http://localhost:3000/api/auth/callback/google
# GitHub: https://next-auth.js.org/providers/github — OAuth App allows one callback URL; set:
#   {NEXTAUTH_URL}/api/auth/callback/github   e.g. http://localhost:3000/api/auth/callback/github
#
# GitHub credentials: use either NextAuth-style names (GITHUB_ID / GITHUB_SECRET) or the same names as
# entrevistas (GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET). Both are accepted; do not duplicate both pairs.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_ID=
# GITHUB_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# BULL_BOARD_SECRET=

# Evolution API / Health Check Config
# PING_TIMEOUT_MS=5000
# RESTART_TIMEOUT_MS=10000

# Public URL of the open-source repository (footer, hero, OSS section). Defaults to oismaelash/evolution-api-monitor on GitHub.
# OPEN_SOURCE_REPO_URL=https://github.com/oismaelash/evolution-api-monitor

# Optional cloud features
CLOUD_BILLING=false
CLOUD_ADVANCED_ALERTS=false
CLOUD_EXPONENTIAL_RETRY=false

# WhatsApp alerts (Pilot Status Integration)
# MONITOR_STATUS_API_KEY=
# MONITOR_STATUS_BASE_URL=https://api.pilotstatus.online
# Template ID approved in Pilot Status (not the per-project alert message body)
# MONITOR_STATUS_TEMPLATE_ID=default
# Login OTP via WhatsApp (same MONITOR_STATUS_API_KEY). Defaults to otp_login_evo_api_manager if unset.
# AUTH_OTP_TEMPLATE_ID=otp_login_evo_api_manager

# Billing Integration (Stripe / Pague Dev)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# BILLING_PRICE_PER_NUMBER_CENTS=500
# PAGUE_DEV_API_KEY=
# PAGUE_DEV_WEBHOOK_SECRET=
# PAGUE_DEV_BASE_URL=https://api.pague.dev/v1
