## Mock Redis para testes de lock
```typescript
// packages/shared/src/test/mock-redis.ts
export class MockRedis {
  private store = new Map<string, { value: string; expiresAt: number }>();

  async set(key: string, value: string, mode: string, ttl: number, flag: string) {
    if (flag === 'NX' && this.store.has(key)) return null;
    this.store.set(key, { value, expiresAt: Date.now() + ttl * 1000 });
    return 'OK';
  }

  async get(key: string) {
    const entry = this.store.get(key);
    if (!entry || entry.expiresAt < Date.now()) return null;
    return entry.value;
  }

  async eval(_script: string, _numkeys: number, key: string, value: string) {
    const entry = this.store.get(key);
    if (entry?.value === value) { this.store.delete(key); return 1; }
    return 0;
  }
}
```

