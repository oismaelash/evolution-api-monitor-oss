{
  "name": "evolution-online",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build --workspace=@monitor/shared && npm run build --workspace=@monitor/database",
    "test:all": "vitest run",
    "push": "npm run test:all && bash scripts/push-ghcr.sh",
    "dev": "npm run dev --workspace=api",
    "dev:worker": "npm run dev --workspace=worker",
    "dev:docker": "docker compose -f docker-compose.dev.yml up --build",
    "build": "npm run build --workspace=@monitor/shared && npm run build --workspace=@monitor/database && npm run build --workspace=api && npm run build --workspace=worker",
    "lint": "npm run lint --workspace=api",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "npm run migrate:dev --workspace=@monitor/database",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=@monitor/database",
    "db:generate": "npm run generate --workspace=@monitor/database",
    "db:seed": "npm run seed --workspace=@monitor/database",
    "test:integration": "vitest run apps/api/integration.test.ts",
    "start": "npm run start --workspace=api",
    "push:checks": "npm run lint && npm run test:all"
  },
  "devDependencies": {
    "vitest": "^2.1.4"
  }
}
